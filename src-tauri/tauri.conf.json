{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ITManager-Dashboard",
  "version": "2.3.0",
  "identifier": "com.esk-it.itmanager-dashboard",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "ITManager Dashboard",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/esk-it/dashboard-it/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIwQTM5MEFGNkRBNTA2QwpSV1JzVU5yMkNqa0tBdGY2bElTbXEyUzh2UGRjNzJMaFdtRnc1enFEbWZtRGdhaURpbWtHTFoxQgo="
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/backend"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
